{
  "name": "bob-queue-consumer-worker",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bob-control-worker",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "../control-worker/migrations"
    }
  ],
  "queues": {
    "consumers": [
      {
        "queue": "bob-runs",
        "max_retries": 100
      }
    ]
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "vars": {
    "LOCAL_QUEUE_SHARED_SECRET": "",
    "RUN_RESUME_STALE_MS": "",
    "CODERUNNER_MODE": "mock",
    "SPRITE_TOKEN": "",
    "SPRITE_NAME": "",
    "SPRITES_API_BASE_URL": "",
    "SPRITES_TIMEOUT_MS": "",
    "CLAUDE_CODE_API_KEY": "",
    "GITHUB_ADAPTER_MODE": "mock",
    "GITHUB_TOKEN": "",
    "GITHUB_API_BASE_URL": ""
  }
}
